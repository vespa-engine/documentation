    "@storybook/html": "10.0.7",
    "babel-loader": "10.0.0",
    "browser-sync": "3.0.4",
    "gulp": "5.0.1",
    "gulp-connect-php": "1.0.3",
    "gulp-rename": "2.0.0",
    "gulp-sass": "6.0.1",
    "mocha": "11.5.0",
    "react-is": "19.1.0"
  },
  "release": {
    "debug": false,
