flowchart TB
  subgraph host["Vespa host (Enclave)"]
    direction TB
    subgraph node["Vespa container / content node"]
      mp["metrics-proxy<br/>/prometheus/v1/values"]
      logs[("Log files<br/>vespa.log, access log")]
    end
    subgraph otc["OpenTelemetry collector"]
      direction TB
      collect["scrape metrics<br/>tail logs"]
      e1["exporter 1<br/>OTLP / HTTP"]
      e2["exporter 2<br/>Google Cloud"]
    end
  end
  b1["Your OTLP backend"]
  b2["Google Cloud<br/>Monitoring and Logging"]
  mp --> collect
  logs --> collect
  collect --> e1
  collect --> e2
  e1 == "push (HTTPS, your auth)" ==> b1
  e2 == "push (HTTPS, workload identity)" ==> b2
